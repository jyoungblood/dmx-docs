---
import "../styles/global.css";
import { Font } from "astro:assets";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Datamix - Edge-Native Content Modeling Studio</title>
    <Font cssVariable="--font-haskoy" preload />
    <style is:global>
      :root {
        --font-display: var(--font-haskoy);
        --font-body: var(--font-haskoy);
      }
    </style>
  </head>
  <body class="bg-white text-black antialiased">
    <div class="relative min-h-screen overflow-hidden">
      <div
        class="pointer-events-none fixed inset-0 z-0 opacity-[0.025]"
        aria-hidden="true"
        style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E&quot;); background-repeat: repeat; background-size: 128px 128px;"
      >
      </div>

      <main
        class="relative z-10 mx-auto flex w-full max-w-none flex-1 flex-col px-6 py-20 sm:px-12 sm:py-28 md:px-[6vw] md:py-36"
      >
        <header class="[font-family:var(--font-display)]">
          <div
            class="flex flex-wrap items-baseline justify-between gap-x-10 gap-y-4text-sm font-normal"
          >
            <span class="font-bold uppercase">Datamix Studio</span>
            <nav
              class="flex flex-wrap items-center gap-x-8 gap-y-2"
              aria-label="Primary"
            >
              <a
                class="border-b border-current decoration-transparent transition-colors hover:text-black"
                href="mailto:jonathan.youngblood@gmail.com"
              >
                Get in touch
              </a>
            </nav>
          </div>
        </header>

        <section class="py-16 sm:py-20 md:py-28">
          <h1
            class="[font-family:var(--font-display)] text-5xl font-semibold uppercase leading-[0.98] tracking-[-0.03em] text-black sm:text-6xl sm:leading-[0.98] md:text-7xl md:leading-[0.97] lg:text-8xl"
          >
            The 1-click content studio built for Cloudflare.
          </h1>
        </section>

        <div class="h-0.5 w-full bg-black" aria-hidden="true"></div>

        <section class="py-16 sm:py-20 md:py-28">
          <div
            class="mb-14 max-w-3xl space-y-10 text-xl font-normal leading-[1.65] text-black sm:mb-20 sm:space-y-12 sm:text-2xl sm:leading-[1.7]"
          >
            <p>
              Datamix is a visual content modeling environment that runs
              entirely in the browser.
            </p>
            <p>
              Define your data structures, and a JSON API is generated
              automatically.
            </p>
            <p>
              No configuration files, no local dependencies, no build pipeline.
            </p>
          </div>

          <div
            class="max-w-3xl space-y-6 text-lg font-normal leading-[1.75] text-black/80 sm:space-y-7 sm:text-xl sm:leading-[1.8]"
          >
            <p>
              <strong class="">Visual content modeling</strong> - define schemas directly
              in the UI
            </p>
            <p>
              <strong class="">Auto-generated JSON API</strong>
              ready to consume immediately
            </p>
            <p>
              <strong class="">Built-in media library</strong> for asset management
            </p>
            <p>
              <strong class="">Role-based access control</strong> for teams
            </p>
            <p>
              <strong class="">Deploys to Cloudflare</strong> in one click - zero
              local setup required
            </p>
          </div>
        </section>

        <section class="py-16 sm:py-20 md:py-28">

          <p
            class="max-w-3xl text-xl font-normal leading-[1.65] text-black sm:text-2xl sm:leading-[1.7]"
          >
            Datamix is currently in active development. <br />More details,
            documentation, and a public release are on the way.
          </p>
        </section>

        <section class="py-16 sm:py-20 md:py-28">
          <p
            class="max-w-3xl text-xl font-normal leading-[1.65] text-black sm:text-2xl sm:leading-[1.7]"
          >
            Interested in early access or collaboration? <br />Get in touch:
            <a
              class="ml-1 border-b border-current text-black transition-colors hover:text-black"
              href="mailto:jonathan.youngblood@gmail.com"
            >
              jonathan.youngblood@gmail.com
            </a>
          </p>
        </section>
      </main>

      <footer
        class="relative z-10 w-full max-w-none px-6 py-14 sm:px-12 md:px-[6vw]"
      >
        <p class="text-sm font-normal">© Datamix 2026</p>
      </footer>
    </div>

    <style>
      .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        margin-right: 0.5rem;
        background: #80efd5;
        animation: pulse 2.5s ease-in-out infinite;
      }

      .feature-item {
        position: relative;
      }

      .feature-item::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0.78em;
        width: 0.85rem;
        height: 2.5px;
        border-radius: 999px;
        background: #80efd5;
      }

      @keyframes pulse {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.35;
        }
      }
    </style>
  </body>
</html>
